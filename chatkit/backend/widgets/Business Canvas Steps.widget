        "children": [
          {
            "type": "Button",
            "label": "B2C",
            "style": "secondary"
          }
        ]
      },
      {
        "type": "Spacer",
        "minSize": 8
      },
      {
        "type": "Row",
        "justify": "center",
        "children": [
          {
            "type": "Button",
            "label": "Geen voorkeur",
            "style": "secondary"
          }
        ]
      },
      {
        "type": "Spacer",
        "minSize": 14
      },
      {

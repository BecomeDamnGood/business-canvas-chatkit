        "minSize": 12
      },
      {
        "type": "Divider"
      },
      {
        "type": "Spacer",
        "minSize": 16
      },
      {
        "type": "Text",
        "value": "Wat is jouw droom voor dit bedrijf over 3 jaar? (max 3 zinnen)"
      },
      {
        "type": "Spacer",
        "minSize": 14
      },
      {
        "type": "Row",
        "justify": "center",
        "children": [
          {
            "type": "Button",
            "label": "B2B",
            "style": "secondary"
          }
        ]
      },
      {
        "type": "Spacer",
        "minSize": 8
      },
      {
        "type": "Row",

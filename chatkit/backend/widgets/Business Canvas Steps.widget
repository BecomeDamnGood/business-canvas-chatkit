{
  "version": "1.0",
  "name": "Business Canvas Steps",
  "template": "{\"type\":\"Card\",\"theme\":\"light\",\"background\":\"white\",\"padding\":24,\"children\":[{\"type\":\"Row\",\"justify\":\"between\",\"children\":[{\"type\":\"Badge\",\"label\":{{ (((\"Stap \" + (stepIndex if stepIndex is defined and stepIndex is not none else 0) + \" van \") ~ ((stepTotal if stepTotal is defined and stepTotal is not none else 0)))) | tojson }}},{\"type\":\"Badge\",\"label\":{{ (stepName if stepName is defined and stepName is not none else \"\") | tojson }}}]},{\"type\":\"Spacer\",\"minSize\":12},{\"type\":\"Divider\"},{\"type\":\"Spacer\",\"minSize\":16},{\"type\":\"Text\",\"value\":{{ (agentMessage if agentMessage is defined and agentMessage is not none else \"\") | tojson }}},{\"type\":\"Spacer\",\"minSize\":14},{\"type\":\"Row\",\"justify\":\"center\",\"children\":[{\"type\":\"Button\",\"label\":{{ (choice1 if choice1 is defined and choice1 is not none else \"\") | tojson }},\"style\":\"secondary\"}]},{\"type\":\"Spacer\",\"minSize\":8},{\"type\":\"Row\",\"justify\":\"center\",\"children\":[{\"type\":\"Button\",\"label\":{{ (choice2 if choice2 is defined and choice2 is not none else \"\") | tojson }},\"style\":\"secondary\"}]},{\"type\":\"Spacer\",\"minSize\":8},{\"type\":\"Row\",\"justify\":\"center\",\"children\":[{\"type\":\"Button\",\"label\":{{ (choice3 if choice3 is defined and choice3 is not none else \"\") | tojson }},\"style\":\"secondary\"}]},{\"type\":\"Spacer\",\"minSize\":14},{\"type\":\"Form\",\"children\":[{\"type\":\"Textarea\",\"name\":\"answer\",\"placeholder\":\"Typ hier je antwoord…\"},{\"type\":\"Spacer\",\"minSize\":10},{\"type\":\"Button\",\"label\":\"Verstuur\",\"style\":\"primary\",\"submit\":true}]}]}",
  "jsonSchema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
      "stepIndex": {
        "type": "number"
      },
      "stepTotal": {
        "type": "number"
      },
      "stepName": {
        "type": "string"
      },
      "agentMessage": {
        "type": "string"
      },
      "choice1": {
        "type": "string"
      },
      "choice2": {
        "type": "string"
      },
      "choice3": {
        "type": "string"
      }
    },
    "additionalProperties": true
  },
  "outputJsonPreview": {
    "type": "Card",
    "theme": "light",
    "background": "white",
    "padding": 24,
    "children": [
      {

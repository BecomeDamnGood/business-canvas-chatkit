{
  "version": "1.0",
  "name": "Business Canvas Steps",
  "template": "{\"type\":\"Card\",\"theme\":\"light\",\"background\":\"white\",\"padding\":24,\"children\":[{\"type\":\"Row\",\"justify\":\"between\",\"children\":[{\"type\":\"Badge\",\"label\":{{ (((\"Stap \" + stepIndex + \" van \") ~ stepTotal)) | tojson }}},{\"type\":\"Badge\",\"label\":{{ (stepName) | tojson }}}]},{\"type\":\"Spacer\",\"minSize\":12},{\"type\":\"Divider\"},{\"type\":\"Spacer\",\"minSize\":16},{\"type\":\"Text\",\"value\":{{ (agentMessage if agentMessage is defined and agentMessage is not none else \"\") | tojson }}},{\"type\":\"Spacer\",\"minSize\":14},{\"type\":\"Col\",\"gap\":8,\"children\":[{\"type\":\"Button\",\"label\":{{ (choice1 if choice1 is defined and choice1 is not none else \"\") | tojson }},\"style\":\"secondary\",\"block\":true},{\"type\":\"Button\",\"label\":{{ (choice2 if choice2 is defined and choice2 is not none else \"\") | tojson }},\"style\":\"secondary\",\"block\":true},{\"type\":\"Button\",\"label\":{{ (choice3 if choice3 is defined and choice3 is not none else \"\") | tojson }},\"style\":\"secondary\",\"block\":true}]},{\"type\":\"Spacer\",\"minSize\":14},{\"type\":\"Form\",\"onSubmitAction\":{\"type\":\"bc.step.submit\"},\"children\":[{\"type\":\"Textarea\",\"name\":\"answer\",\"placeholder\":\"Typ hier je antwoord…\"},{\"type\":\"Spacer\",\"minSize\":10},{\"type\":\"Button\",\"label\":\"Verstuur\",\"style\":\"primary\",\"submit\":true,\"block\":true}]}]}",
  "jsonSchema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
      "stepIndex": {
        "type": "number"
      },
      "stepTotal": {
        "type": "number"
      },
      "stepName": {
        "type": "string"
      },
      "agentMessage": {
        "type": "string"
      },
      "choice1": {
        "type": "string"
      },
      "choice2": {
        "type": "string"
      },
      "choice3": {
        "type": "string"
      }
    },
    "additionalProperties": true
  },
  "outputJsonPreview": {
    "type": "Card",
    "theme": "light",
    "background": "white",
    "padding": 24,
    "children": [
      {
        "type": "Row",
        "justify": "between",
        "children": [
          {
            "type": "Badge",
            "label": "Stap 2 van 9"
          },
          {
            "type": "Badge",
            "label": "Dream"
          }
        ]
      },
      {
        "type": "Spacer",
        "minSize": 12
      },
      {
        "type": "Divider"
      },
      {
        "type": "Spacer",
        "minSize": 16
      },
      {
        "type": "Text",
        "value": "Wat is jouw droom voor dit bedrijf over 3 jaar? (max 3 zinnen)"
      },
      {
        "type": "Spacer",
        "minSize": 14
      },
      {
        "type": "Col",
        "gap": 8,
        "children": [
          {
            "type": "Button",
            "label": "B2B",
            "style": "secondary",
            "block": true
          },
          {
            "type": "Button",
            "label": "B2C",
            "style": "secondary",
            "block": true
          },
          {
            "type": "Button",
            "label": "Geen voorkeur",
            "style": "secondary",
            "block": true
          }
        ]
      },
      {
        "type": "Spacer",
        "minSize": 14
      },
      {
        "type": "Form",
        "onSubmitAction": {
          "type": "bc.step.submit"
        },
        "children": [
          {
            "type": "Textarea",
            "name": "answer",
            "placeholder": "Typ hier je antwoord…"
          },
          {
            "type": "Spacer",
            "minSize": 10
          },
          {
            "type": "Button",
            "label": "Verstuur",
            "style": "primary",
            "submit": true,
            "block": true
          }
        ]
      }
    ]
  },
  "encodedWidget": "-XG4gIDwvUm93PlxuXG4gIDxTcGFjZXIgbWluU2l6ZT17MTJ9IC8-XG4gIDxEaXZpZGVyIC8-XG4gIDxTcGFjZXIgbWluU2l6ZT17MTZ9IC8-XG5cbiAgPFRleHQgdmFsdWU9e2FnZW50TWVzc2FnZSA_PyBcIlwifSAvPlxuXG4gIDxTcGFjZXIgbWluU2l6ZT17MTR9IC8--XG4gICAgPEJ1dHRvbiBsYWJlbD1cIlZlcnN0dXVyXCIgc3R5bGU9XCJwcmltYXJ5XCIgc3VibWl0IGJsb2NrIC8-XG4gIDwvRm9ybT5cbjwvQ2FyZD5cbiIsImRlZmF1bHRTdGF0ZSI6eyJzdGVwSW5kZXgiOjIsInN0ZXBUb3RhbCI6OSwic3RlcE5hbWUiOiJEcmVhbSIsImFnZW50TWVzc2FnZSI6IldhdCBpcyBqb3V3IGRyb29tIHZvb3IgZGl0IGJlZHJpamYgb3ZlciAzIGphYXI_"

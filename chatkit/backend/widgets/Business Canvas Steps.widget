            "placeholder": "Typ hier je antwoord…"
          },
          {
            "type": "Spacer",
            "minSize": 10
          },
          {
            "type": "Button",
            "label": "Verstuur",
            "style": "primary",
            "submit": true
          }
        ]
      }
    ]
  },
